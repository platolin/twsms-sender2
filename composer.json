{
  "name": "platolin/twsms-sender",
  "description": "Minimal TWsms sender package for PHP 8.2+",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": "^8.2"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0",
    "phpstan/phpstan": "^1.11",
    "friendsofphp/php-cs-fixer": "^3.59"
  },
  "autoload": {
    "psr-4": {
      "Twsms\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Twsms\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit",
    "analyze": "phpstan analyse --debug",
    "cs": "php-cs-fixer fix --dry-run --diff"
  }
}
